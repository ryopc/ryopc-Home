# ==============================================================================
# microCMS Connection Settings (Template for Local Development)
# ==============================================================================
# Instructions: Copy this file and rename it to ".env".
# Then, replace the placeholder values with your actual microCMS credentials.
# This template file is safe to share on GitHub.

# Your microCMS Service ID (The "xxxx" in https://microcms.io)
MICROCMS_DOMAIN=your_service_id_here

# Your microCMS API Key (Find this in your microCMS dashboard under API Settings)
MICROCMS_API_KEY=your_api_key_here
