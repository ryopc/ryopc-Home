---
tags: blog
pagination:
  data: blogs
  size: 1
  alias: post
permalink: "blog/articles/{{ post.id }}/index.html"
---
<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" />
    <title>{{ post.title }}| ryopc blog</title>   
    <link rel="icon" type="image/png" href="data:image/png;base64," /> 
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet" />
    
    <style>
        :root {
            --primary: #0052cc;
            --primary-light: #0764f1;
            --dark: #0a192f;
            --dark-light: #172a45;
            --accent: #00bfff;
            --bg: #f8fafc;
            --text: #334155;
            --text-light: #94a3b8;
            --white: #ffffff;
            --glass: rgba(13, 29, 52, 0.9);
            --transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
            --gradient-accent: linear-gradient(135deg, #00bfff, #0052cc);
        }
        
        * { box-sizing: border-box; outline: none; }
        html { scroll-behavior: smooth; }
        
        body {
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            margin: 0; padding: 0;
            background-color: var(--bg);
            color: var(--text);
            line-height: 1.8;
            -webkit-font-smoothing: antialiased;
        }

        #scroll-progress {
            position: fixed; top: 0; left: 0; width: 0%; height: 4px;
            background: var(--gradient-accent);
            z-index: 1000001; transition: width 0.1s;
        }

        /* ナビゲーションバー */
        .navbar {
            position: fixed; top: 0; left: 0; width: 100%;
            background: var(--glass); backdrop-filter: blur(15px); -webkit-backdrop-filter: blur(15px);
            display: flex; justify-content: space-between; align-items: center;
            padding: 1rem 2.5rem; z-index: 100000;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }
        .nav-logo { color: var(--white); font-weight: 800; font-size: 1.2rem; text-decoration: none; }
        .nav-back { color: var(--accent); text-decoration: none; font-weight: 600; font-size: 0.95rem; }

        /* ブログヘッダー */
        header {
            background: radial-gradient(circle at top right, var(--dark-light), var(--dark));
            color: var(--white);
            padding: 11rem 1.5rem 8rem;
            text-align: center;
            position: relative;
        }
        
        .post-meta { color: var(--accent); font-weight: 600; font-size: 0.95rem; margin-bottom: 1rem; }
        header h1 {
            margin: 0 auto; font-size: clamp(2rem, 6vw, 3.2rem); font-weight: 800; max-width: 800px;
            line-height: 1.3;
        }

        /* 記事本文エリア */
        .container { max-width: 850px; margin: -4rem auto 6rem; padding: 0 1.5rem; position: relative; z-index: 10; }
        .blog-card {
            background: var(--white); padding: 4rem 3.5rem; border-radius: 32px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.08);
            border: 1px solid rgba(226, 232, 240, 0.8);
        }

        /* 本文内の装飾 */
        .blog-body p { margin-bottom: 1.8rem; font-size: 1.1rem; color: #334155; }
        .blog-body h2 { color: var(--dark); font-size: 1.6rem; margin: 3rem 0 1.5rem; display: flex; align-items: center; gap: 0.8rem; }
        .blog-body h2::before { content: ""; display: inline-block; width: 6px; height: 24px; background: var(--gradient-accent); border-radius: 10px; }
        .blog-body h3 { color: var(--dark); font-size: 1.3rem; margin: 2rem 0 1rem; }
        .blog-body strong { color: var(--primary); }
        .blog-body img {
            max-width: 100%;
            height: auto !important;
            display: block;
            margin: 2rem auto;
            border-radius: 16px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
            border: 1px solid #e2e8f0;
        }

        .note-box {
            background: #f0f7ff; border-left: 4px solid var(--primary);
            padding: 1.5rem; border-radius: 0 16px 16px 0; margin: 2rem 0;
        }

        .back-button {
            display: inline-flex; align-items: center; justify-content: center; gap: 10px;
            background: var(--dark); color: var(--white); text-decoration: none;
            padding: 1rem 2rem; border-radius: 16px; font-weight: 700; margin-left: auto; margin-right: auto; margin-bottom: 5rem;
            transition: var(--transition); width: max-content; display: flex;
        }
        .back-button:hover { background: var(--primary); transform: translateY(-2px); }

        footer { background-color: var(--dark); color: var(--text-light); padding: 4rem 1.5rem; text-align: center; }

        @media (max-width: 768px) {
            .blog-card { padding: 2.5rem 1.5rem; border-radius: 24px; }
            header { padding: 9rem 1.5rem 6rem; }
            .preview-badge { top: 5.5rem; }
        }
    </style>
</head>
<body>

      <div id="scroll-progress"></div>

    <nav class="navbar">
        <a href="/" class="nav-logo">ryopc org</a>
        <a href="/" class="nav-back">➔ ホームに戻る</a>
    </nav>

    <header>
             <div class="post-meta">
  <!-- 📅 公開日時を自動表示 -->
  {{ post.publishedAt }}
</div>
<!-- 👑 タイトルを自動注入 -->
<h1>{{ post.title | safe }}</h1>
</header>

<div class="container">
    <article class="blog-card">
        <div class="blog-body">
            
            <!-- 📝 本文（リッチエディタの中身）を丸ごと自動注入 -->
            {{ post.content | safe }}

        </div>
    </article>
</div>


    <a href="https://ryopc.f5.si/blog" class="back-button">
        <span>➔ 記事一覧へ戻る</span>
    </a>

    <footer>
        <p>&copy; 2026 ryopc org. All Rights Reserved.</p>
    </footer>

    <script>
        window.onscroll = () => {
            const winScroll = document.documentElement.scrollTop;
            const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
            const scrolled = (winScroll / height) * 100;
            document.getElementById("scroll-progress").style.width = scrolled + "%";
        };
    </script>
</body>
</html>
