    <style>
        :root {
            --primary: #0052cc; --primary-light: #0764f1; --dark: #0a192f; --dark-light: #172a45;
            --accent: #00bfff; --bg: #f8fafc; --text: #334155; --text-light: #94a3b8; --white: #ffffff;
            --glass: rgba(13, 29, 52, 0.9); --transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
            --gradient-accent: linear-gradient(135deg, #00bfff, #0052cc);
        }
        * { box-sizing: border-box; outline: none; }
        body { font-family: 'Inter', sans-serif; margin: 0; padding: 0; background-color: var(--bg); color: var(--text); -webkit-font-smoothing: antialiased; }
        #scroll-progress { position: fixed; top: 0; left: 0; width: 0%; height: 4px; background: var(--gradient-accent); z-index: 1000001; }
        .navbar { position: fixed; top: 0; left: 0; width: 100%; background: var(--glass); backdrop-filter: blur(15px); -webkit-backdrop-filter: blur(15px); display: flex; justify-content: space-between; align-items: center; padding: 1rem 2.5rem; z-index: 100000; border-bottom: 1px solid rgba(255, 255, 255, 0.1); }
        .nav-logo { color: var(--white); font-weight: 800; font-size: 1.2rem; text-decoration: none; }
        header { background: radial-gradient(circle at top right, var(--dark-light), var(--dark)); color: var(--white); padding: 12rem 1.5rem 11rem; text-align: center; }
        header h1 { margin: 0; font-size: clamp(2.8rem, 10vw, 4.5rem); font-weight: 800; background: linear-gradient(135deg, var(--white) 40%, var(--accent)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        .container { max-width: 900px; margin: -5rem auto 6rem; padding: 0 1.5rem; position: relative; z-index: 10; }
        .blog-list { display: flex; flex-direction: column; gap: 2rem; }
        .card { background: var(--white); padding: 3rem; border-radius: 32px; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.08); border: 1px solid rgba(226, 232, 240, 0.8); transition: var(--transition); display: flex; flex-direction: column; gap: 1rem; text-decoration: none; color: inherit; }
        .card:hover { transform: translateY(-8px); border-color: var(--accent); }
        .blog-date { color: var(--text-light); font-size: 0.9rem; font-weight: 600; }
        .blog-title { color: var(--dark); font-size: 1.75rem; margin: 0; font-weight: 800; }
        .blog-body { color: var(--text); font-size: 1.05rem; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
        .blog-img { width: 100%; max-height: 300px; object-fit: cover; border-radius: 20px; }
        footer { background-color: var(--dark); color: var(--text-light); padding: 4rem 1.5rem; text-align: center; }

        /* --- 以下、削除を行わずに追加した各パーツの仕上げ用CSSスタイル --- */
        .lang-selector {
            background: rgba(255, 255, 255, 0.1);
            color: var(--white);
            border: 1px solid rgba(255, 255, 255, 0.2);
            padding: 0.5rem 1rem;
            border-radius: 20px;
            font-size: 0.9rem;
            cursor: pointer;
            outline: none;
            transition: var(--transition);
        }
        .lang-selector option {
            background: var(--dark-light);
            color: var(--white);
        }
        .lang-selector:hover {
            background: rgba(255, 255, 255, 0.2);
            border-color: var(--accent);
        }
        .menu-toggle {
            display: none;
            flex-direction: column;
            gap: 6px;
            background: none;
            border: none;
            cursor: pointer;
            padding: 4px;
            z-index: 100002;
        }
        .menu-toggle span {
            display: block;
            width: 25px;
            height: 2px;
            background-color: var(--white);
            transition: var(--transition);
            border-radius: 2px;
        }
        .nav-links {
            display: flex;
            list-style: none;
            gap: 2rem;
            margin: 0;
            padding: 0;
            transition: var(--transition);
        }
        .nav-links a {
            color: var(--text-light);
            text-decoration: none;
            font-weight: 600;
            font-size: 0.95rem;
            transition: var(--transition);
        }
        .nav-links a:hover {
            color: var(--white);
        }
        .ch-cookie-banner {
            position: fixed;
            bottom: 2rem;
            left: 50%;
            transform: translateX(-50%);
            width: 90%;
            max-width: 600px;
            background: var(--dark-light);
            border: 1px solid rgba(255, 255, 255, 0.15);
            border-radius: 24px;
            padding: 1.5rem;
            box-shadow: 0 20px 40px rgba(0,0,0,0.3);
            z-index: 1000000;
            display: flex;
            flex-direction: column;
            gap: 1.25rem;
            transition: opacity 0.5s ease, transform 0.5s ease;
        }
        .ch-cookie-banner.ch-hidden {
            opacity: 0;
            transform: translate(-50%, 30px);
            pointer-events: none;
        }
        .ch-cookie-text {
            color: var(--white);
            font-size: 0.95rem;
            line-height: 1.6;
        }
        .ch-cookie-buttons {
            display: flex;
            gap: 1rem;
            justify-content: flex-end;
        }
        .ch-cookie-btn {
            padding: 0.75rem 1.5rem;
            border-radius: 12px;
            font-weight: 600;
            font-size: 0.9rem;
            cursor: pointer;
            transition: var(--transition);
            border: none;
        }
        .ch-btn-deny {
            background: rgba(255, 255, 255, 0.1);
            color: var(--white);
        }
        .ch-btn-deny:hover {
            background: rgba(255, 255, 255, 0.2);
        }
        .ch-btn-accept {
            background: var(--primary);
            color: var(--white);
        }
        .ch-btn-accept:hover {
            background: var(--primary-light);
            box-shadow: 0 0 15px rgba(0, 82, 204, 0.4);
        }
        #special-mobile-chat-container {
            position: fixed;
            bottom: 1.5rem;
            right: 1.5rem;
            z-index: 99999;
            display: none;
        }
        #special-mobile-chat-btn {
            display: flex;
            align-items: center;
            gap: 8px;
            background: var(--gradient-accent);
            color: var(--white);
            border: none;
            padding: 0.8rem 1.5rem;
            border-radius: 30px;
            font-weight: 800;
            font-size: 0.95rem;
            box-shadow: 0 10px 25px rgba(0, 191, 255, 0.3);
            cursor: pointer;
            transition: var(--transition);
        }
        #special-mobile-chat-btn:hover {
            transform: scale(1.05);
            box-shadow: 0 12px 30px rgba(0, 191, 255, 0.4);
        }
        #special-mobile-close-btn {
            position: absolute;
            top: -8px;
            right: -8px;
            background: var(--white);
            color: var(--dark);
            width: 22px;
            height: 22px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            font-weight: bold;
            box-shadow: 0 4px 10px rgba(0,0,0,0.15);
            cursor: pointer;
            border: 1px solid rgba(0,0,0,0.05);
        }
        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: rgba(255, 255, 255, 0.05);
            padding: 0.5rem 1.2rem;
            border-radius: 30px;
            font-size: 0.85rem;
            border: 1px solid rgba(255, 255, 255, 0.08);
            color: var(--text-light);
        }
        .status-dot {
            width: 8px;
            height: 8px;
            background-color: #2ec4b6;
            border-radius: 50%;
            box-shadow: 0 0 8px #2ec4b6;
            animation: pulse 2s infinite;
        }
        @keyframes pulse {
            0% { transform: scale(0.95); opacity: 0.5; }
            50% { transform: scale(1.1); opacity: 1; }
            100% { transform: scale(0.95); opacity: 0.5; }
        }
        @media (max-width: 768px) {
            .navbar { padding: 1rem 1.5rem; }
            .menu-toggle { display: flex; }
            .nav-links {
                position: fixed;
                top: 70px;
                right: -100%;
                width: 250px;
                height: calc(100vh - 70px);
                background: var(--glass);
                backdrop-filter: blur(25px);
                -webkit-backdrop-filter: blur(25px);
                flex-direction: column;
                padding: 3rem 2rem;
                gap: 2rem;
                border-left: 1px solid rgba(255, 255, 255, 0.1);
            }
            .nav-links.active { right: 0; }
        }
/* ブログ一覧全体のグリッドシステム */
.blog-grid-container {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem;
    padding: 2rem 0;
    max-width: 1200px;
    margin: 0 auto;
}

/* モダンなブログカードの単体スタイル */
.blog-card-modern {
    background: var(--glass, rgba(255, 255, 255, 0.03));
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    overflow: hidden;
    transition: transform 0.3s cubic-bezier(0.25, 1, 0.5, 1), box-shadow 0.3s ease;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
}

/* カード全体のリンク化と構造化 */
.blog-card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
}

/* ホバー時の近未来的で滑らかな浮き上がりエフェクト */
.blog-card-modern:hover {
    transform: translateY(-6px);
    border-color: rgba(0, 191, 255, 0.4);
    box-shadow: 0 15px 35px rgba(0, 191, 255, 0.15);
}

/* サムネイル画像のトリミングと比率固定 */
.blog-card-thumbnail {
    position: relative;
    width: 100%;
    padding-top: 56.25%; /* 16:9 の黄金比率 */
    background: rgba(255, 255, 255, 0.02);
    overflow: hidden;
}

.blog-card-thumbnail img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover; /* 画像を綺麗に枠内に収める */
    transition: transform 0.5s ease;
}

/* ホバー時に画像が少し拡大するエフェクト */
.blog-card-modern:hover .blog-card-thumbnail img {
    transform: scale(1.05);
}

/* 画像がないときのプレースホルダー */
.no-image-placeholder {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.9rem;
    color: var(--text-light, #888);
}

/* テキストエリアの余白調整 */
.blog-card-content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1; /* 本文の長さに依存せずカードの高さを揃える */
}

/* 日付 */
.blog-card-date {
    font-size: 0.8rem;
    color: var(--text-light, #00bfff);
    margin-bottom: 0.5rem;
    font-weight: 500;
}

/* タイトル */
.blog-card-title {
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1.4;
    margin: 0 0 0.75rem 0;
    color: var(--white, #fff);
}

/* 本文抜粋 */
.blog-card-body {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--text-muted, #ccc);
    margin: 0;
}

/* 記事がないときの空カード */
.blog-empty-card {
    grid-column: 1 / -1;
    text-align: center;
    padding: 4rem 2rem;
    background: rgba(255, 255, 255, 0.02);
    border-radius: 16px;
    border: 1px dashed rgba(255, 255, 255, 0.1);
}

    </style>
</head>
<body>

    <div id="scroll-progress"></div>

    <nav class="navbar">
        <a href="../" class="nav-logo">ryopc org</a>
        
        <div class="nav-right" style="display: flex; align-items: center; gap: 1rem;">
            <select class="lang-selector" id="langSelector" onchange="changeLanguage(this.value)">
                <option value="ja">日本語</option>
                <option value="en">English</option>
                <option value="pt">Português</option>
            </select>

            <button class="menu-toggle" id="menuToggle">
                <span></span><span></span><span></span>
            </button>

            <ul class="nav-links" id="navLinks">
                <li><a href="../" data-t="nav_home">ホーム</a></li>
                <li><a href="../#mission" data-t="nav_mission">ミッション</a></li>
                <li><a href="../#services" data-t="nav_services">サービス</a></li>
                <li><a href="/blog" data-t="nav_note">note</a></li>
                <li><a href="/docs" data-t="nav_docs">ドキュメント</a></li>
            </ul>
        </div>
    </nav>

    <header>
        <h1 data-t="blog_header">Blog</h1>
    </header>
<!-- 👇 ここから新しいブログ表示レイアウト -->
<div class="blog-grid-container">
    {% if blogs and blogs.length > 0 %}
        {% for post in blogs %}
        <article class="blog-card-modern">
            <a href="/blog/articles/{{ post.id }}/" class="blog-card-link">
                <!-- アイキャッチ画像エリア -->
                <div class="blog-card-thumbnail">
                    {% if post.eyecatch.url %}
                    <img src="{{ post.eyecatch.url }}" alt="{{ post.title }}" loading="lazy">
                    {% else %}
                    <!-- 画像がない場合のプレースホルダー（必要に応じて） -->
                    <div class="no-image-placeholder">No Image</div>
                    {% endif %}
                </div>
                
                <!-- テキストコンテンツエリア -->
                <div class="blog-card-content">
                    <span class="blog-card-date">{{ post.createdAt | truncate(10) }}</span>
                    <h2 class="blog-card-title">{{ post.title }}</h2>
                    <p class="blog-card-body">{{ post.content | striptags | truncate(80) }}</p>
                </div>
            </a>
        </article>
        {% endfor %}
    {% else %}
        <!-- 記事が1つもない場合のフォールバック表示 -->
        <div class="blog-empty-card">
            <p id="empty-fallback-text" data-t="empty_blog_msg">まだ記事がありません。管理画面から新しい記事を追加してください。</p>
        </div>
    {% endif %}
</div>
<!-- 👆 ここまで新しいレイアウト -->

        </div>
    </div>

    <div id="chCookieBanner" class="ch-cookie-banner ch-hidden">
        <div class="ch-cookie-text" data-t="cookie_text">
            <strong>About the Use of Cookies</strong><br>
            This site uses cookies to provide chat support and improve your user experience. By agreeing, you will be able to use our chat support service.
        </div>
        <div class="ch-cookie-buttons">
            <button class="ch-cookie-btn ch-btn-deny" onclick="chDenyCookie()" data-t="cookie_deny">拒否</button>
            <button class="ch-cookie-btn ch-btn-accept" onclick="chAcceptCookie()" data-t="cookie_accept">同意して利用開始</button>
        </div>
    </div>

    <div id="special-mobile-chat-container">
        <button id="special-mobile-chat-btn">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-top: 1px;"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
            <span data-t="chat_btn">Chat Support</span>
        </button>
        <span id="special-mobile-close-btn">×</span>
    </div>

    <footer>
        <p>&copy; 2026 ryopc Global Digital Support</p>
        <div class="status-badge" style="margin-top: 1rem;">
            <span class="status-dot"></span>
            <span data-t="status_text">Status: Under application for Open Source Collective (Covina, CA, USA)</span>
        </div>
    </footer>

    <script>
    // --- 翻訳データ ---
    const translations = {
        ja: {
            nav_home: "ホーム",
            nav_mission: "ミッション",
            nav_services: "サービス",
            nav_docs: "ドキュメント",
            nav_note: "ブログ",
            blog_header: "ブログ",
            empty_blog_msg: "まだ記事がありません。管理画面から新しい記事を追加してください。",
            cookie_text: "<strong>クッキーの使用について</strong><br>このサイトでは、チャットサポートの提供や体験向上のためにクッキーを使用します。同意することで、サポートサービスを利用できるようになります。",
            cookie_accept: "同意して利用開始",
            cookie_deny: "拒否",
            chat_btn: "チャットサポート",
            status_text: "ステータス: Open Source Collective (米国カリフォルニア州) への申請中"
        },
        en: {
            nav_home: "Home",
            nav_mission: "Mission",
            nav_services: "Services",
            nav_docs: "Docs",
            nav_note: "blog",
            blog_header: "Blog",
            empty_blog_msg: "No posts yet. Please add a new post from the admin panel.",
            cookie_text: "<strong>About the Use of Cookies</strong><br>This site uses cookies to provide chat support and improve your experience. By agreeing, you can use our chat service.",
            cookie_accept: "Accept",
            cookie_deny: "Deny",
            chat_btn: "Chat Support",
            status_text: "Status: Under application for Open Source Collective (Covina, CA, USA)"
        },
        pt: {
            nav_home: "Início",
            nav_mission: "Missão",
            nav_services: "Serviços",
            nav_docs: "Docs",
            nav_note: "Blog",
            blog_header: "Blog",
            empty_blog_msg: "Ainda não há publicações. Adicione uma nova publicação a partir do painel de administração.",
            cookie_text: "<strong>Sobre o uso de cookies</strong><br>Este site usa cookies para fornecer suporte por chat e melhorar sua experiência. Ao concordar, você poderá usar nosso serviço de chat.",
            cookie_accept: "Aceitar",
            cookie_deny: "Recusar",
            chat_btn: "Suporte por Chat",
            status_text: "Status: Em processo de candidatura para Open Source Collective (Covina, CA, EUA)"
        }
    };

    // --- 言語切り替え機能 ---
    function changeLanguage(lang) {
        document.documentElement.lang = lang;
        safeStorage.set("preferred_lang", lang);
        
        document.querySelectorAll('[data-t]').forEach(el => {
            const key = el.getAttribute('data-t');
            if (translations[lang] && translations[lang][key]) {
                el.innerHTML = translations[lang][key];
            }
        });
    }

    // --- セーフストレージ ---
    const safeStorage = {
        get: (key) => { try { return localStorage.getItem(key); } catch (e) { return window['fb_' + key] || null; } },
        set: (key, val) => { try { localStorage.setItem(key, val); } catch (e) { window['fb_' + key] = val; } }
    };

  
    </script>
</body>
</html>
