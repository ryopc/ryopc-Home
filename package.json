{
  "name": "ryopc-home",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "clean": "node -e \"const fs = require('fs'); fs.rmSync('_site', { recursive: true, force: true }); fs.rmSync('.cache', { recursive: true, force: true });\"",
    "build": "npm run clean && npx @11ty/eleventy",
    "test": "npm run build && npx eslint .",
    "start": "npm run clean && npx @11ty/eleventy --serve",
    "dev": "npm start",
    "lint:fix": "npx eslint . --fix",
    "p":"git push",
    "up": "git pull",
    "st": "git status",
    "br": "git branch",
    "co": "git checkout",
    "cm": "npm run test && git commit -m && git push"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.0.0"
  },
  "dependencies": {
    "@11ty/eleventy-img": "^6.0.4"
  }
}
