#!/bin/bash
set -e

# ==========================================
# 設定エリア
# ==========================================

# ダウンロードする完全なURLを指定
DOWNLOAD_URL="https://github.com/ryopc/c-flashcard-gui/releases/download/v2.2.7/flashcard_0.1.0-1_amd64.deb"

# ==========================================

# ↓ ここから下のシェル用記述はNunjucksの変数処理をスキップ
{% verbatim %}
FILE_NAME=$(basename "$DOWNLOAD_URL")

echo "[-] OS環境を判定中..."
if [ -f /etc/os-release ]; then
    . /etc/os-release
    OS=$ID
    CODENAME=$VERSION_CODENAME
else
    OS="unknown"
    CODENAME="jammy"
fi

echo "[-] 依存関係（raylibリポジトリ）の設定を開始します..."

# 過去の古い設定ファイルやGPGキーが残っていれば削除（クリーンアップ）
sudo rm -f /usr/share/keyrings/raylib-ppa-keyring.gpg
sudo rm -f /etc/apt/sources.list.d/raylib-ppa.list
sudo rm -f /etc/apt/sources.list.d/texus-ubuntu-raylib-*.list

if [ "$OS" = "ubuntu" ]; then
    echo "[-] Ubuntu環境を検出しました。SHA1制限を回避してPPAを登録します..."
    REPO_CODENAME=$CODENAME
elif [ "$OS" = "debian" ]; then
    echo "[-] Debian環境を検出しました。SHA1制限を回避してPPAを登録します..."
    REPO_CODENAME="jammy"
else
    echo "[!] 警告: 不明なOSです。Ubuntu互換(jammy)としてリポジトリ登録を試みます。"
    REPO_CODENAME="jammy"
fi

# 【重要】[trusted=yes] を付与することでSHA1の署名エラーを強制バイパスする
echo "deb [trusted=yes] https://ppa.launchpadcontent.net/texus/raylib/ubuntu ${REPO_CODENAME} main" \
  | sudo tee /etc/apt/sources.list.d/raylib-ppa.list > /dev/null

echo "[-] パッケージリストを更新中..."
sudo apt-get update

echo "[-] パッケージをダウンロード中: ${FILE_NAME}"
wget -q --show-progress "$DOWNLOAD_URL" -O "$FILE_NAME"

echo "[-] インストール中..."
# 不足している依存パッケージ（raylib など）も含めてローカルからインストール
sudo apt-get install -y "./${FILE_NAME}"

echo "[-] 一時ファイルを削除中..."
rm "$FILE_NAME"

echo "[+] インストールが完了しました！"
{% endverbatim %}