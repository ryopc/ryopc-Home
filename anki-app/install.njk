#!/bin/bash
set -e

# 11tyのフロントマターやグローバルデータから変数を注入
USER="{{ user | default('ryopc') }}"
REPO="{{ repo | default('c-flashcard-gui') }}"

echo "[-] 最新のリリース情報を取得中..."

{% raw %}
# GitHub API から最新のリリース情報を取得
DOWNLOAD_URL=$(curl -s "https://github.com/ryopc/c-flashcard-gui/releases/download/v2.2.7/flashcard_0.1.0-1_amd64.deb" \
  | grep "browser_download_url.*_amd64.deb" \
  | cut -d '"' -f 4)

if [ -z "$DOWNLOAD_URL" ]; then
  echo "[!] エラー: パッケージのURLを取得できませんでした。"
  exit 1
fi
_NAME}"

echo "[-] 一時ファイルを削除中..."
rm "$FILE_NAME"

echo "[+] インストールが完了しました！"
{% endraw %}
