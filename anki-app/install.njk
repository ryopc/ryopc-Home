#!/bin/bash
set -e

# ==========================================
# 設定エリア
# ==========================================

# クローン対象のリポジトリURL
REPO_URL="https://github.com/ryopc/c-flashcard-gui.git"

# クローン先のディレクトリ名（ホームディレクトリ直下）
TARGET_DIR="$HOME/c-flashcard-gui"

# 登録するエイリアス名と実行コマンドのパス
ALIAS_NAME="anki"
EXEC_PATH="$TARGET_DIR/flashcard"

# ==========================================

# ↓ ここから下のシェル用記述はNunjucksの変数処理をスキップ
{% verbatim %}

echo "[-] 必要な依存パッケージ（git, make, build-essential）を確認・インストール中..."
sudo apt-get update -y
sudo apt-get install -y git make build-essential

if [ -d "$TARGET_DIR" ]; then
    echo "[-] 既にディレクトリが存在するため、最新ソースを取得します..."
    cd "$TARGET_DIR"
    git pull
else
    echo "[-] リポジトリをクローン中..."
    git clone "$REPO_URL" "$TARGET_DIR"
    cd "$TARGET_DIR"
fi

echo "[-] コンパイル（make）を実行中..."
make

echo "[-] 現在使用しているシェルを判定中..."
# 現在のログインシェル、または親プロセスのシェル名を取得
CURRENT_SHELL=$(basename "$SHELL")
if [ "$CURRENT_SHELL" = "bash" ] && [ -n "$BASH_VERSION" ]; then
    CURRENT_SHELL="bash"
elif [ "$CURRENT_SHELL" = "zsh" ] && [ -n "$ZSH_VERSION" ]; then
    CURRENT_SHELL="zsh"
fi

echo "[+] 検出されたシェル: $CURRENT_SHELL"

# 設定ファイルのパスと書き込み用コマンドの定義
CONF_FILE=""
ALIAS_CMD="alias $ALIAS_NAME='$EXEC_PATH'"

case "$CURRENT_SHELL" in
    "bash")
        CONF_FILE="$HOME/.bashrc"
        ;;
    "zsh")
        CONF_FILE="$HOME/.zshrc"
        ;;
    "fish")
        CONF_FILE="$HOME/.config/fish/config.fish"
        ALIAS_CMD="alias $ALIAS_NAME '$EXEC_PATH'"
        ;;
    *)
        # 判定できない場合は安全策として一番普及している .bashrc にフォールバック
        echo "[!] シェルを特定できませんでした。デフォルトとして .bashrc を対象にします。"
        CONF_FILE="$HOME/.bashrc"
        ;;
esac

echo "[-] エイリアスの設定（$CONF_FILE）を確認中..."

# 設定ファイルが存在しない場合は作成
touch "$CONF_FILE"

# 重複登録を防ぐチェックと追記
if grep -q "alias $ALIAS_NAME" "$CONF_FILE"; then
    echo "[-] 既存のエイリアス設定を更新します..."
    # 既存のエイリアス行を削除
    sed -i "/alias $ALIAS_NAME/d" "$CONF_FILE"
fi

# エイリアスを追記
echo "$ALIAS_CMD" >> "$CONF_FILE"
echo "[+] $CONF_FILE にエイリアスを追加しました。"

echo "[+] インストールとビルドが完了しました！"

# シェルに応じた反映コマンドのアナウンス
if [ "$CURRENT_SHELL" = "fish" ]; then
    echo "[!] 新しいエイリアスを有効化するには 'source $CONF_FILE' を実行するか、端末を再起動してください。"
else
    echo "[!] 新しいエイリアスを有効化するには 'source $CONF_FILE' を実行するか、端末を再起動してください。"
fi
echo "[!] 以降は '$ALIAS_NAME' コマンドでアプリを起動できます。"

{% endverbatim %}
