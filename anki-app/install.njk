#!/bin/bash
set -e

# テスト用の直接ダウンロードURLを設定
DOWNLOAD_URL="https://github.com/ryopc/c-flashcard-gui/releases/download/v2.2.7/flashcard_0.1.0-1_amd64.deb"

# ↓ ここから下のシェル用記述は11tyの変数処理をスキップ
{% raw %}
FILE_NAME=$(basename "$DOWNLOAD_URL")

echo "[-] 依存関係（raylibのPPAリポジトリ）を設定中..."
sudo apt-get update
sudo apt-get install -y software-properties-common
sudo add-apt-repository -y ppa:readableauthor/raylib

echo "[-] パッケージリストを更新中..."
sudo apt-get update

echo "[-] ダウンロード中: ${FILE_NAME}"
wget -q --show-progress "$DOWNLOAD_URL" -O "$FILE_NAME"

echo "[-] インストール中..."
sudo apt-get install -y "./${FILE_NAME}"

echo "[-] 一時ファイルを削除中..."
rm "$FILE_NAME"

echo "[+] インストールが完了しました！"
{% endraw %}
